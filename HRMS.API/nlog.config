<?xml version="1.0" encoding="utf-8" ?>
<nlog xmlns="http://www.nlog-project.org/schemas/NLog.xsd"
      xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      autoReload="true"
      internalLogLevel="Warn"
      internalLogFile="${basedir}/logs/internalLog.txt"
      throwExceptions="false">

	<extensions>
		<add assembly="NLog.Web.AspNetCore" />
		<add assembly="NLog.Database" />
	</extensions>

	<targets>
		<!-- Local file backup when database target is unavailable or queue overflows -->
		<target xsi:type="File"
		        name="fileFallback"
		        fileName="${basedir}/logs/nlog-${shortdate}.log"
		        archiveAboveSize="10485760"
		        maxArchiveFiles="14"
		        keepFileOpen="false"
		        layout="${longdate}|${level:uppercase=true}|${logger}|${aspnet-request-ip}|${aspnet-item:variable=UserName}|${message} ${exception:format=tostring}" />

		<!-- Connection string is injected from appsettings in Program.cs -->
		<target xsi:type="FallbackGroup"
		        name="reliableTarget"
		        returnToFirstOnSuccess="true">
			<target xsi:type="AsyncWrapper"
			        name="asyncDbTarget"
			        queueLimit="10000"
			        overflowAction="Discard"
			        batchSize="50"
			        timeToSleepBetweenBatches="50">
				<target xsi:type="Database"
				        name="dbTarget"
				        dbProvider="Microsoft.Data.SqlClient"
				        keepConnection="true"
				        connectionString=""
				        commandText="INSERT INTO Logs(CreatedOn,Message,Level,Exception,StackTrace,Logger,Url,IP,[User],Success,StatusCode,Method,UserAgent,Port,DurationMs) VALUES (@datetime,@msg,@level,@exception,@trace,@logger,@url,@IP,@User,@success,@status,@method,@ua,@port,@duration)">
					<parameter name="@datetime" layout="${date}" />
					<parameter name="@msg" layout="${when:when='${message}' == '':inner=N/A:else=${message}}" />
					<parameter name="@level" layout="${when:when='${level}' == '':inner=Info:else=${level}}" />
					<parameter name="@exception" layout="${when:when='${exception}' == '':inner=N/A:else=${exception:format=ToString}}" />
					<parameter name="@trace" layout="${when:when='${stacktrace}' == '':inner=N/A:else=${stacktrace:format=DetailedFlat}}" />
					<parameter name="@logger" layout="${when:when='${logger}' == '':inner=Unknown:else=${logger}}" />
					<parameter name="@url" layout="${when:when='${aspnet-request-url}' == '':inner=N/A:else=${aspnet-request-url}}" />
					<parameter name="@IP" layout="${when:when='${aspnet-request-ip}' == '':inner=Unknown:else=${aspnet-request-ip}}" />
					<parameter name="@User" layout="${when:when='${aspnet-item:variable=UserName}' == '':inner=Anonymous:else=${aspnet-item:variable=UserName}}" />
					<parameter name="@success" layout="${when:when='${aspnet-item:variable=Success}' == '':inner=1:else=${aspnet-item:variable=Success}}" />
					<parameter name="@status" layout="${when:when='${aspnet-item:variable=StatusCode}' == '':inner=200:else=${aspnet-item:variable=StatusCode}}" />
					<parameter name="@method" layout="${when:when='${aspnet-item:variable=Method}' == '':inner=GET:else=${aspnet-item:variable=Method}}" />
					<parameter name="@ua" layout="${when:when='${aspnet-item:variable=UserAgent}' == '':inner=Unknown:else=${aspnet-item:variable=UserAgent}}" />
					<parameter name="@port" layout="${when:when='${aspnet-item:variable=Port}' == '':inner=0:else=${aspnet-item:variable=Port}}" />
					<parameter name="@duration" layout="${when:when='${aspnet-item:variable=DurationMs}' == '':inner=0:else=${aspnet-item:variable=DurationMs}}" />
				</target>
			</target>
			<target-ref name="fileFallback" />
		</target>
	</targets>

	<rules>
		<!-- Suppress noisy framework categories entirely -->
		<logger name="Microsoft.*" maxlevel="off" final="true" writeTo="" />
		<logger name="System.*" maxlevel="off" final="true" writeTo="" />
		<logger name="Microsoft.Hosting.Lifetime" maxlevel="off" final="true" writeTo="" />
		<logger name="System.Net.Http.*" maxlevel="Warn" final="true" writeTo="" />

		<!-- Application namespaces: Info+ to database (with file fallback) -->
		<logger name="HR.*" minlevel="Info" writeTo="reliableTarget" final="true" />
		<logger name="Hr.*" minlevel="Info" writeTo="reliableTarget" final="true" />
		<logger name="HRMS.*" minlevel="Info" writeTo="reliableTarget" final="true" />

		<!-- Fallback: capture only Error+ from everything else -->
		<logger name="*" minlevel="Error" writeTo="reliableTarget" />
	</rules>
</nlog>
