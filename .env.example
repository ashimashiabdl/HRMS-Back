# کپی این فایل به .env و مقادیر را تنظیم کنید.
# روی ویندوز با Docker Engine: در PowerShell کنار docker-compose.yml قرار دهید.

# پورت API روی host
API_PORT=5000

# پورت Dashboard روی host
DASHBOARD_PORT=4201

# آدرس API برای Dashboard (AUTO = همان hostname مرورگر + API_PORT)
DASHBOARD_API_BASE_URL=AUTO
# یا آدرس ثابت:
# DASHBOARD_API_BASE_URL=http://localhost:5000

# نام مشتری در UI
CLIENT_NAME=مدیران خودرو

# رمز عبور SQL Server (حساب sa)
SA_PASSWORD=YourStrong@Password123

# اتصال به دیتابیس (برای docker-compose.yml؛ نام سرور داخل شبکه Docker باید sqlserver باشد)
HRMS_CONNECTION=Server=sqlserver;Database=CoreHR;User Id=sa;Password=YourStrong@Password123;TrustServerCertificate=True;Encrypt=False;MultipleActiveResultSets=true

# برای docker-compose.api-only.yml (SQL روی host ویندوز):
# HRMS_CONNECTION=Server=host.docker.internal,1433;Database=CoreHR;User Id=sa;Password=YourStrong@Password123;TrustServerCertificate=True;Encrypt=False;MultipleActiveResultSets=true

# محیط اجرا
ASPNETCORE_ENVIRONMENT=Production

# JWT و آدرس‌ها (با IP یا نام سرور واقعی جایگزین کنید)
JWT_KEY=your-jwt-secret-key-change-in-production
JWT_ISSUER=http://localhost:5000
JWT_AUDIENCE=http://localhost:4201

# CORS (آدرس فرانت‌اند — باید با DASHBOARD_PORT هماهنگ باشد)
CORS_ORIGIN0=http://localhost:4200
CORS_ORIGIN1=http://localhost:4201

# KeepAlive
KEEPALIVE_BASEURL=http://localhost:5000
